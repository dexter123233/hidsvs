# 12-Factor App Configuration
# Environment Variable template for Zavod

# --- Infrastructure ---
# Factor IV: Backing Services
DB_HOST=localhost
DB_PORT=5432
DB_USER=zavod_admin
DB_PASS=encrypted_secret_here
VECTOR_DB_URL=http://chromadb:8000

# --- AI / LLM Settings ---
# Factor III: Config
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4o
PROMPT_VERSION=v2.1.0

# --- Compliance & Security ---
# Secrets should be injected via AWS Secrets Manager in production
CONSENT_LEDGER_ENDPOINT=https://ledger.internal.zavod.ai
ENCRYPTION_KEY_ID=alias/zavod-kms-key

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=zavod-extraction-service
